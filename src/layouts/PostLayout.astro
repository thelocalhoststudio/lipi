---
import siteConfig from "@/site.config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { type Post, getPostUrl, getPostSlug, getAllPosts, getRelatedPosts } from "@/utils/content";
import { calculateReadingTime, slugify } from "@/utils/text";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import SharePost from "@/components/content/SharePost.astro";
import SEO from "@/components/SEO.astro";
import PostFeed from "@/components/content/PostFeed.astro";
import PostNavigation from "@/components/content/PostNavigation.astro";
import { generatePostSchema } from "@/utils/schema";

type Props = {
  post: Post;
  prevPost?: Post | null;
  nextPost?: Post | null;
};

const {
  post,
  prevPost,
  nextPost,
} = Astro.props;

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}

function formatMonthYear(date: Date) {
  return new Intl.DateTimeFormat("en", {
    year: "numeric",
    month: "long",
  })
    .format(date)
    .toUpperCase();
}
const { title, description, cover, published, updated, tags } = post.data;

const allPosts    = await getAllPosts();
const relatedPosts = getRelatedPosts(post, allPosts, siteConfig.relatedPosts);

const updatedDate = updated
  ? formatDate(updated)
  : formatDate(published);

const section = post.data.category ?? "Posts";
const readTime    = calculateReadingTime(post.body ?? "").text;
const showReadingTime = siteConfig.showReadingTime || false;

const ogImage = `/og/posts/${getPostSlug(post.id, post.filePath)}.png`;

const structuredData = generatePostSchema(post);
---

<BaseLayout schema={structuredData}>
  <SEO
    slot="seo"
    {title}
    description={description ?? ""}
    type="article"
    publishedTime={published}
    {tags}
    {ogImage}
  />
  <Fragment slot="header">
    <Breadcrumb />
    <!-- Post Header -->
    <header class="space-y-4">
      <!-- Context -->
      <div class="text-muted-foreground flex flex-wrap items-center gap-3 text-xs font-medium tracking-widest mb-1 sm:mb-2">
        <span>{section}</span>
      </div>

      <!-- Title -->
      <div class="space-y-4">
        <h1 
          class="font-display text-foreground text-4xl sm:text-5xl sm:mt-0 leading-normal tracking-tight"
          transition:name={slugify(post.data.title.replaceAll(".", "-"))}
        >
          {post.data.title}
        </h1>

        {
          post.data.description && (
            <p class="text-muted-foreground max-w-2xl text-sm sm:text-base leading-snug">
              {post.data.description}
            </p>
          )
        }
      </div>

      <!-- Metadata -->
      <div class="text-muted-foreground flex flex-wrap items-center gap-x-3 gap-y-2 mt-8 text-sm">
        <span>
          {post.data.author ?? `${siteConfig.author}`}
        </span>

        <span aria-hidden="true">·</span>

        <time datetime={post.data.published.toISOString()}>
          {updatedDate}
        </time>

        {
          showReadingTime && (
            <>
              <span aria-hidden="true">
                ·
              </span>
              <span>
                {readTime}
              </span>
            </>
          )
        }
      </div>

      <!-- Tags -->
      {
        post.data.tags &&
          post.data.tags.length > 0 && (
            <div class="flex flex-wrap items-center gap-3">
              {post.data.tags.map(
                (tag) => (
                  <a
                    href={`/tags/${slugify(tag)}`}
                    class="text-xs font-ui text-muted-foreground hover:text-accent transition-colors no-underline"
                  >
                    {tag}
                  </a>
                )
              )}
            </div>
          )
      }
      <div class="divider" />
    </header>
  </Fragment>

  <section>
    <!-- Cover -->
      {
        post.data.cover && (
          <div class="overflow-hidden rounded-2xl pt-4">
	            <img
	              src={
	                typeof post.data.cover === "string"
                  ? post.data.cover
                  : post.data.cover.src
	              }
	              alt={post.data.title}
	              decoding="async"
	              fetchpriority="high"
	              loading="eager"
	              class="aspect-3/2 w-full object-cover outline-1 -outline-offset-1 outline-black/10 dark:outline-white/10"
	            />
          </div>
        )
      }
    <article data-pagefind-body>
    <meta data-pagefind-meta="title[content]" content={title} />
    <meta data-pagefind-sort="date[content]" content={published.toISOString()} />
	    <meta data-pagefind-filter="collection[content]" content={post.collection} />
    {tags?.map((tag) => (
      <meta data-pagefind-filter="tag[content]" content={tag} />
    ))}
    <!-- Content -->
	    <div class="app-prose post-content">
	      <slot />
	    </div>
      <div class="section-divider flex items-center justify-center gap-4 text-muted-foreground mt-4 text-xl" aria-hidden="true">
        <span>·</span>
        <span>·</span>
        <span>·</span>
      </div>
	  </article>
    <SharePost title={post.data.title} />
  </section>
  
  <Fragment slot="navigation">
    <PostNavigation
      prevPost={prevPost}
      nextPost={nextPost}
    />
  </Fragment>
  <Fragment slot="after">
    {relatedPosts.length > 0 && (
      <PostFeed
        posts={relatedPosts}
        variant="archive"
        sectionTitle="Related"
      />
    )}
  </Fragment>
  <Fragment slot="scripts">
    <ReadingProgress />
  </Fragment>
</BaseLayout>
