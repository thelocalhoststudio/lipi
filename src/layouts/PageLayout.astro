---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import SEO from "@/components/SEO.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import siteConfig from "@/site.config";
import { type Page, type Post } from "@/utils/content";

interface Props {
  entry?: Page | Post;
  title?: string;
  description?: string;
  showBreadcrumb?: boolean;
  transitionName?: string;
  noindex?: boolean;
  schema?: Record<string, unknown>;
  showHeader?: boolean;
}

const {
  entry,
  title: propTitle,
  description: propDescription,
  showBreadcrumb = true,
  transitionName,
  noindex = false,
  schema,
  showHeader = true,
} = Astro.props;

// Pages: entry annotation takes precedence over the global fallback.
const footerAnnotation = entry?.data.annotation ?? siteConfig.annotation;

const {
  title: entryTitle,
  description: entryDescription,
  published,
  updated,
} = entry?.data ?? {};

const title =
  propTitle ??
  entryTitle;

const description =
  propDescription ??
  entryDescription;

const last = updated ? updated : published;

const formattedDate = last?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
});

const ogImage = entry
  ? `/og/${entry.id}.png`
  : undefined;

---
<BaseLayout schema={schema}>
  <SEO
    slot="seo"
    title={title}
    description={description ?? ""}
    ogImage={ogImage}
    {noindex}
  />
  <Fragment slot="header">
    {showBreadcrumb && <Breadcrumb />}

    {
      showHeader &&
      <PageHeader {title} subheading={description} transitionName={transitionName} >
      {formattedDate && (
        <div slot="meta" class="">
          <span class="text-muted-foreground text-xs font-code">Updated {formattedDate}</span>
        </div>
      )}
    </PageHeader>
    }
  </Fragment>
  <section>
    <slot />
  </section>
  <Fragment slot="footer">
    <Footer annotation={footerAnnotation} />
  </Fragment>
</BaseLayout>
