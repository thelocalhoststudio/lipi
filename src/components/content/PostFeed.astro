---
import { type Post } from "@/utils/content";
import SectionHeader from "@/components/SectionHeader.astro";
import PostFeedItem, {
  type PostFeedVariant,
  type VariantConfig,
} from "./PostFeedItem.astro";

export type { PostFeedVariant };

const variantConfigs: Record<PostFeedVariant, VariantConfig> = {
  featured: {
    showDescription: true,
    showReadingTime: true,
    titleClass: "font-content text-3xl leading-snug font-medium md:text-4xl",
    contentSpacingClass: "pb-16",
  },
  timeline: {
    showDescription: false,
    showReadingTime: false,
    titleClass: "font-content text-2xl leading-snug font-medium",
    contentSpacingClass: "pb-10 sm:pl-4",
  },
  archive: {
    showDescription: false,
    showReadingTime: false,
    titleClass: "font-content text-base leading-snug",
    contentSpacingClass: "py-1.5",
  },
};

type Props = {
  posts: Post[];
  variant?: PostFeedVariant;
  sectionTitle?: string;
  sectionDesc?: string;
};

const {
  posts,
  variant = "archive",
  sectionTitle,
  sectionDesc,
} = Astro.props;

const config = variantConfigs[variant];
---

<section>
  <SectionHeader title={sectionTitle} subheading={sectionDesc} />

  {variant === "featured" && (
    <div>
      {posts.map((post) => (
        <PostFeedItem post={post} variant="featured" />
      ))}
    </div>
  )}

  {variant === "timeline" && (
    <div class="timeline">
      {posts.map((post) => (
        <PostFeedItem post={post} variant="timeline" />
      ))}
    </div>
  )}

  {variant === "archive" && (
    <ul class="space-y-1">
      {posts.map((post) => (
        <li>
          <PostFeedItem post={post} variant="archive" />
        </li>
      ))}
    </ul>
  )}
</section>

