---
import { getPostUrl, type Post } from "@/utils/content";
import { slugify } from "@/utils/text";
import PostTitle from "./PostTitle.astro";
import PostMeta from "@/components/content/PostMeta.astro";
import SectionHeader from "@/components/SectionHeader.astro";

type Props = {
  post: Post;
};

const { post } = Astro.props;
const { description } = post.data;

const url = getPostUrl(post.id, post.filePath);
const sectionTitle = "Featured"
---

<section class="my-2 md:my-4 py-4">

  <SectionHeader title={sectionTitle} />
  <article class="featured-post md:max-w-xl">
    <div class="flex flex-col">
      <div class="flex flex-col gap-2">
        <PostTitle post={post}
          class="text-2xl md:text-3xl font-medium mt-0 text-balance" />
        <div class="post-meta flex flex-row items-baseline gap-2 mb-2 text-xs font-ui text-muted-foreground">
          <PostMeta post={post} showReadingTime />
        </div>

        {/* Description */}
        {description && (
          <p
            class="text-sm md:text-sm italic leading-normal text-muted-foreground md:max-w-xl">
            {description}
          </p>
        )}

        {/* CTA row */}
        <div class="flex md:flex-row flex-wrap items-center gap-4 mt-4">
          <a href={url}
            class="group inline-cta text-muted-foreground hover:text-foreground"
            aria-label={`Read: ${post.data.title}`}
          >
            <span class="inline-cta-line group-hover:w-16"></span>
            Continue reading
          </a>
        </div>
      </div>
    </div>
  </article>
</section>
