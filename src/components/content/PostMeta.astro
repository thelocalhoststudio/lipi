---
import { type Post } from "@/utils/content";
import { calculateReadingTime } from "@/utils/text";
import siteConfig from "@/site.config";

type Props = {
  post: Post;
  showReadingTime?: boolean;
  showLanguage?: boolean;
  accentCategory?: boolean;
};

const {
  post,
  showReadingTime = false,
  showLanguage = false,
  accentCategory = false,
} = Astro.props;

const { category, published, updated, lang } = post.data;

const displayDate = new Intl.DateTimeFormat("en", {
  month: "short",
  year: "numeric",
}).format(updated ?? published);

const readingTime =
  siteConfig.showReadingTime && showReadingTime
    ? calculateReadingTime(post.body ?? "").text
    : null;
---
{
  category && (
    <span
      class:list={[
        "",
        { "text-primary": accentCategory },
      ]}
    >
      {category}
    </span>
  )
}

<time
  datetime={published.toISOString()}
  class="tabular-nums"
>
  {displayDate}
</time>

{
  readingTime && (
    <span>
      {readingTime}
    </span>
  )
}

{
  showLanguage && lang && (
    <span class="uppercase">
      {lang}
    </span>
  )
}