---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
  caption?: string;
  bare?: boolean;
  quality?: number;
  fetchPriority?: 'auto' | 'high' | 'low';
}

const {
  src,
  alt,
  width = 900,
  height = 600,
  class: className,
  loading = 'lazy',
  caption,
  bare = false,
  quality = 80,
  fetchPriority = "auto",
} = Astro.props;

const imageClass = [
  "block w-full h-auto",
  className,
]
  .filter(Boolean)
  .join(" ");

const isAstroImage = (src: unknown): src is ImageMetadata =>
  typeof src === 'object' && src !== null && 'src' in src;
---

{src && bare && (
  isAstroImage(src) ? (
    <Picture
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      formats={['avif', 'webp']}
      quality={quality}
      class={imageClass}
      fetchpriority={fetchPriority}
    />
  ) : (
    <img src={src} alt={alt} loading={loading} class={imageClass} />
  )
)}

{src && !bare && (
  <figure class="border border-border rounded-sm overflow-hidden">
    {isAstroImage(src) ? (
      <Picture
        src={src}
        alt={alt}
        width={width}
        height={height}
        loading={loading}
        decoding="async"
        formats={['avif', 'webp']}
        quality={quality}
        class={className}
      />
    ) : (
      <img src={src} alt={alt} loading={loading} class={imageClass} />
    )}
    {caption && (
      <figcaption class="mt-2 text-sm text-center text-muted-foreground leading-snug">{caption}</figcaption>
    )}
  </figure>
)}